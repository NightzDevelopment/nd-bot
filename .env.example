# Discord, Bot token; enable Message Content, Server Members, Message Content, Voice
DISCORD_BOT_TOKEN=

# Google AI Studio, https://aistudio.google.com/apikey
GOOGLE_API_KEY=

GEMINI_MODEL=gemini-3-flash-preview
# Optional: comma-separated Gemini fallback models tried when primary fails/timeouts.
# GEMINI_FALLBACK_MODELS=gemini-3.1-pro-preview,gemini-2.5-flash,gemini-2.5-flash-lite,gemini-2.0-flash-lite,gemini-1.5-flash
# Optional secondary provider: OpenAI (used in mode=openai or auto fallback).
# OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_FALLBACK_MODELS=gpt-4.1-mini
# OPENAI_TIMEOUT_MS=45000
# Max bytes for image attachments (vision); default 3 MiB
IMAGE_ATTACHMENT_MAX_BYTES=3145728
# ZIP analysis attachments (default 10 MiB, scan up to 40 files, 600 chars per text file snippet)
# ZIP_ATTACHMENT_MAX_BYTES=10485760
# ZIP_ATTACHMENT_MAX_FILES=40
# ZIP_ATTACHMENT_MAX_FILE_CHARS=600

# --- ND keywords & Discord-specific context (appended to guild + DM system prompts) ---
# Set to 0 to disable appending the built-in ND vocabulary + extras below
ND_KEYWORDS_APPEND=1
# Extra lines (your server’s roles, channels, slang, product nicknames). Use real newlines in .env or one long line.
# ND_KEYWORDS_CONTEXT=
# Optional path (relative to cwd) to a .txt/.md file with more keywords (merged after built-in defaults)
ND_KEYWORDS_FILE=data/nd-knowledge.md

ENABLE_DM_SUPPORT=1
ALLOWED_DM_USER_IDS=

GUILD_CHANNEL_IDS=

# Parent category ID(s): ND ticket channels under this category get AI for the opener on every message until staff claims/posts (see tickets.json staffEngaged). Without a bot ticket record, only the first message from that user still triggers AI.
# GUILD_AI_TICKET_CATEGORY_IDS=1364400365457510511

# Guild AI: ms of active window after @mention/reply (default 120000 = 2 min)
ACTIVE_CONVERSATION_MS=120000

# Comma-separated role IDs treated as moderators (in addition to Admin / Manage Guild / Moderate Members)
MOD_ROLE_ID=
WARN_TIMEOUT_THRESHOLD=3
WARN_KICK_THRESHOLD=5

AUTOMOD_ENABLED=1
AUTOMOD_BLOCK_INVITES=1
AUTOMOD_MAX_MENTIONS=5
AUTOMOD_MAX_LINKS=4
AUTOMOD_MAX_DUPES=3
AUTOMOD_DUPE_WINDOW_SEC=10
AUTOMOD_FAST_MSG_COUNT=6
AUTOMOD_FAST_MSG_WINDOW_SEC=5

# URL phishing / typosquat heuristics (rule automod; no Gemini)
URL_RISK_ENABLED=1
URL_RISK_BLOCK_SCORE=70
URL_RISK_DELETE_MESSAGE=1
# Extra safe domains (comma), always skipped by URL risk
URL_RISK_TRUSTED_HOSTS=nightz.dev,github.com,google.com,youtube.com,imgur.com

# AI AutoMod HEATED verdict: channel slowmode seconds (0 = disabled). Needs Manage Channels.
HEATED_SLOWMODE_SECONDS=0
HEATED_SLOWMODE_COOLDOWN_MS=300000

# When bot replies in these channel IDs, mirror a staff copy-paste draft to STAFF_LOG_CHANNEL_ID
STAFF_DRAFT_SOURCE_CHANNEL_IDS=

# nd!translate limits
TRANSLATE_COOLDOWN_MS=15000
TRANSLATE_HOURLY_MAX=12

AI_AUTOMOD_ENABLED=1
AI_AUTOMOD_TOXICITY=1
AI_AUTOMOD_SCAM=1
AI_AUTOMOD_NSFW=1
AI_AUTOMOD_RAID=1
AI_AUTOMOD_SENTIMENT=1
AI_AUTOMOD_IMPERSONATION=1
AI_AUTOMOD_MIN_CONFIDENCE=0.80
AI_AUTOMOD_BATCH_SIZE=5
# Idle poll ms (work also runs as soon as a message is enqueued)
AI_AUTOMOD_BATCH_INTERVAL_MS=500
AI_AUTOMOD_MAX_CALLS_PER_MINUTE=10
RAID_JOIN_THRESHOLD=10
RAID_JOIN_WINDOW_SEC=60
RAID_NEW_ACCOUNT_DAYS=7
# Log joins where Discord account is newer than RAID_NEW_ACCOUNT_DAYS (staff log)
RAID_NEW_ACCOUNT_ALERT_ENABLED=1

# Extra AI AutoMod categories (1/0)
AI_AUTOMOD_HATE=1
AI_AUTOMOD_SELFHARM=1
AI_AUTOMOD_DOXXING=1
AI_AUTOMOD_SPAM_AD=1
AI_AUTOMOD_CRYPTO_SCAM=1
# Optional multiline policy appended to the classifier (use \n in value or real newlines in .env)
# AI_AUTOMOD_SERVER_RULES=
# Include reply parent + recent channel lines (1/0)
AI_AUTOMOD_INCLUDE_REPLY_CONTEXT=1
AI_AUTOMOD_INCLUDE_CHANNEL_SNIPPET=0
# Classify first image when message is image-only (costs API calls)
AI_AUTOMOD_VISION=0
AI_AUTOMOD_VISION_MAX_PER_MINUTE=5
# Per-verdict override: none | log | delete | timeout | log,delete | log,delete,timeout
# AI_AUTOMOD_ACTION_TOXICITY_HIGH=log,delete,timeout
# AI_AUTOMOD_TIMEOUT_MIN_TOXICITY_HIGH=10

# Rule AutoMod: block dangerous attachment extensions (comma, no dot)
AUTOMOD_BLOCKED_ATTACHMENT_EXT=exe,scr,bat,cmd,msi,ps1,hta,jar,com,vbs,reg
# Optional single regex (no slashes) against full URLs; test carefully
# AUTOMOD_URL_BLOCKLIST_REGEX=
# Ratio of non-Latin letters in a message to treat as mixed-script spam (0.35 to 1)
AUTOMOD_HOMOGLYPH_SCRIPT_RATIO=0.55

# Ticket handoff (buttons after AI suggests a ticket)
TICKET_OFFER_ENABLED=1
TICKET_OFFER_COOLDOWN_MS=120000
# Post to staff channel only (safest); set 0 to try forum threads
TICKET_STAFF_INTAKE_ONLY=1
# Forum channel ID for private threads (optional if TICKET_STAFF_INTAKE_ONLY=1)
# TICKET_FORUM_CHANNEL_ID=
# Auto-create ticket without button (use only in test channels)
TICKET_AUTO_CREATE=0
# TICKET_AUTO_CREATE_CHANNEL_IDS=

# --- ND ticket system (private channels + panel; replaces Ticket Tool) ---
# Set to 0 to disable the built-in ticket system (panel deploy, channel tickets, transcripts)
TICKET_SYSTEM_ENABLED=1
# Panel channel: dropdown + Open Ticket button (bot edits this message on restart)
TICKET_PANEL_CHANNEL_ID=1364400105423114250
# Categories: open tickets live here; closed tickets moved here (read-only for user)
TICKET_OPEN_CATEGORY_ID=1364400365457510511
TICKET_CLOSED_CATEGORY_ID=1364400425121480756
# Ticket open/claim/close log (defaults to STAFF_LOG_CHANNEL_ID)
# TICKET_LOG_CHANNEL_ID=
# Comma-separated reasons for the panel dropdown (max 25 options)
# TICKET_REASONS=Buying Product,Technical Help,Script Support,Account/Role Issues,Billing/Refund,Commission Inquiry,Suggestions,Report a Problem,Partnership/Collaboration,Other
TICKET_MAX_OPEN_PER_USER=3
TICKET_TRANSCRIPT_ENABLED=1
# Max messages scanned for transcripts (50–5000, paginated)
# TICKET_TRANSCRIPT_MAX_MESSAGES=2000
# Styled HTML transcript alongside .txt (Ticket Tool–style). Set 0 to disable.
# TICKET_TRANSCRIPT_HTML=1
# DM the ticket opener when a ticket is closed (1/0)
TICKET_DM_ON_CLOSE=0
# Inactivity auto-close: hours with no message from ticket opener before warning (0 = off)
TICKET_AUTO_CLOSE_HOURS=0
# Hours after the warning before the bot auto-closes the ticket
TICKET_AUTO_CLOSE_GRACE_HOURS=12
# Channel name prefix (ticket-0001, closed-0001)
# TICKET_NAMING=ticket
# Comma-separated workflow labels for the staff status dropdown (max 25). First = default for new tickets.
# TICKET_WORKFLOW_STATUSES=Open,Claimed,In progress,Waiting on user,On hold,Resolved (ready to close)

# User reports (/report, nd!report): optional separate channel; defaults to STAFF_LOG
# REPORT_CHANNEL_ID=
REPORT_COOLDOWN_MS=300000
REPORT_MAX_BODY_LENGTH=1500

# nd!links / /links: JSON array of {"label":"...","url":"https://..."}
# SUPPORT_LINKS_JSON=
# Product shortcuts: KEY:url comma-separated (KEY uppercase, no spaces)
# PRODUCT_ALIAS_URLS=ND_DISCORDUNIFIED:https://example.com

# Trust & safety copy (optional extra markdown for /safety)
# SAFETY_EXTRA_MARKDOWN=
# AI / privacy notice (default shown in /privacy, automod public, mod automod status)
# AI_MONITORING_NOTICE=
# Public automod blurb for /automod_public (overrides default block including AI_MONITORING_NOTICE)
# AUTOMOD_PUBLIC_BLURB=

AUDIT_LOG_CHANNEL_ID=
AUDIT_IGNORED_CHANNELS=
# Comma-separated category (parent) IDs, skip audit + rule/AI automod for every channel under them
AUDIT_IGNORED_CATEGORY_IDS=

TEMPVC_LOBBY_ID=
TEMPVC_CATEGORY_ID=
TEMPVC_DEFAULT_LIMIT=0

SUGGESTION_CHANNEL_ID=

STAFF_LOG_CHANNEL_ID=
DM_LOG_CHANNEL_ID=

# Native Discord polls: log votes to staff + one “final hour” ping in the polls channel
# POLL_MONITOR_ENABLED=1
# Your polls channel only (comma-separated if you ever split). Legacy: POLL_MONITOR_CHANNEL_IDS
# POLL_REMINDER_CHANNEL_IDS=
# Override staff log for vote events (defaults to STAFF_LOG_CHANNEL_ID)
# POLL_STAFF_LOG_CHANNEL_ID=
# Hours remaining when the reminder fires once (default 1)
# POLL_REMINDER_HOURS_BEFORE=1
# here | everyone — reminder posts in the same channel as the poll
# POLL_REMINDER_PING=here
# POLL_LOG_VOTES=1

CONVERSATION_HISTORY_LIMIT=30
WELCOME_CHANNEL_ID=
WELCOME_ROLE_ID=
# Optional overrides for welcome embed links (defaults are set in src/config.ts for ND Discord)
WELCOME_RULES_CHANNEL_ID=
WELCOME_NEW_PRODUCTS_CHANNEL_ID=
WELCOME_UPDATES_CHANNEL_ID=
WELCOME_GENERAL_CHANNEL_ID=
WELCOME_SUPPORT_CHANNEL_ID=
WELCOME_TICKET_CHANNEL_ID=
FAQ_CHANNEL_ID=
# FAQ pin refresh interval in ms (default 30 minutes)
# FAQ_REFRESH_MS=1800000

# AI context: when DEV_BUILD_PATHS is set, it replaces DEV_BUILD_PATH (comma and/or newline between paths).
DEV_BUILD_PATH=D:\Nightz Development\Nightz Development Scripts\[ND_Discord]\[Dev Build]
# Nightz ND_Discord [Dev Build], all product folders (copy into your .env; one line or multiple lines)
DEV_BUILD_PATHS=D:\Nightz Development\Nightz Development Scripts\[ND_Discord]\[Dev Build]\[DiscordUnified]\ND_DiscordUnified [Dev Build],D:\Nightz Development\Nightz Development Scripts\[ND_Discord]\[Dev Build]\[DiscordUnified]\ND_Scenes [Dev Build],D:\Nightz Development\Nightz Development Scripts\[ND_Discord]\[Dev Build]\[DiscordUnified]\ND_VehicleSpawner [Dev Build],D:\Nightz Development\Nightz Development Scripts\[ND_Discord]\[Dev Build]\[AFK]\ND_AFKV3 [Dev Build],D:\Nightz Development\Nightz Development Scripts\[ND_Discord]\[Dev Build]\[Axon]\ND_AxonUnified [Dev Build],D:\Nightz Development\Nightz Development Scripts\[ND_Discord]\[Dev Build]\[Framework]\ND_ParkingMeter [Dev Build],D:\Nightz Development\Nightz Development Scripts\[ND_Discord]\[Dev Build]\[HUD]\ND_HUDV2 [Dev Build],D:\Nightz Development\Nightz Development Scripts\[ND_Discord]\[Dev Build]\[HUD]\ND_GraveScript [Dev Build],D:\Nightz Development\Nightz Development Scripts\[ND_Discord]\[Dev Build]\[Other]\ND_CalmAI [Dev Build],D:\Nightz Development\Nightz Development Scripts\[ND_Discord]\[Dev Build]\[PoliceRadar]\ND_SentinelJammer [Dev Build],D:\Nightz Development\Nightz Development Scripts\[ND_Discord]\[Dev Build]\[PoliceRadar]\ND_SentinelRadar [Dev Build],D:\Nightz Development\Nightz Development Scripts\[ND_Discord]\[Dev Build]\[PoliceRadar]\ND_Wars2X [Dev Build],D:\Nightz Development\Nightz Development Scripts\[ND_Discord]\[Dev Build]\[Weapons]\ND_DeadlyWeapons [Dev Build],D:\Nightz Development\Nightz Development Scripts\[ND_Discord]\[Dev Build]\[Weapons]\ND_Gore [Dev Build]
# Coming soon, uncomment and append to DEV_BUILD_PATHS when those folders exist on disk:
# D:\Nightz Development\Nightz Development Scripts\[ND_Discord]\[Dev Build]\[Framework]\ND_Inventory
# D:\Nightz Development\Nightz Development Scripts\[ND_Discord]\[Dev Build]\[Framework]\ND_Fuel
# D:\Nightz Development\Nightz Development Scripts\[ND_Discord]\[Dev Build]\[Framework]\ND_Framework [Dev Build]
# D:\Nightz Development\Nightz Development Scripts\[ND_Discord]\[Dev Build]\[Framework]\ND_Shops
# D:\Nightz Development\Nightz Development Scripts\[ND_Discord]\[Dev Build]\[Weapons]\ND_Taser [Dev Build]
# Official store: https://store.nightz.dev/
CODEBASE_REFRESH_MINUTES=10
# Narrow AI context: max files per reply, one resource folder only, exclude paths (comma substrings)
CODEBASE_MAX_FILES=6
CODEBASE_SINGLE_RESOURCE_MODE=1
CODEBASE_EXCLUDE_PATH_SUBSTRINGS=ND_Menu,ND_Framework
# Random “coming soon” deflection (no Gemini) when message matches these names (comma). Min 4 chars per token after normalizing.
COMING_SOON_REPLIES_ENABLED=1
COMING_SOON_RESOURCES=ND_Menu,ND_Framework,ND_Fuel,ND_Inventory,ND_Shops,ND_Taser
# Comma-separated: words, @everyone, or URL prefixes ending in /* (e.g. discord.gg/*)
EXTRA_BANNED_WORDS=

DATA_DIR=./data

# Persist per-channel AI chat history across restarts (JSON file under DATA_DIR)
PERSISTENT_MEMORY=1
# CONVERSATION_MEMORY_FILE=conversation-memory.json

# Curated per-product docs (markdown files, e.g. data/products/ND_MyScript.md)
PRODUCT_DOCS_DIR=data/products
# PRODUCT_DOCS_MAX_FILES=3

# Semantic (embedding) retrieval over FAQ + product docs + dev index (optional; uses extra API calls)
VECTOR_RETRIEVAL_ENABLED=0
# EMBEDDING_MODEL=text-embedding-004
# VECTOR_TOP_K=5
# EMBEDDING_REFRESH_MINUTES=30
# EMBEDDING_MAX_CHUNK_CHARS=800
# EMBEDDING_MAX_CORPUS_CHUNKS=400

# --- Voice TTS: bot joins VC and speaks AI replies via Google Cloud Text-to-Speech ---
# Requires: Google Cloud project with TTS API enabled
# Auth: GOOGLE_APPLICATION_CREDENTIALS (service account JSON) or GOOGLE_TTS_API_KEY
VOICE_TTS_ENABLED=0
# GOOGLE_APPLICATION_CREDENTIALS=C:/path/to/your-service-account.json
# GOOGLE_TTS_API_KEY=
# Auto-join this VC channel on startup (optional; users can also use nd!join / /join)
# VOICE_AUTO_JOIN_CHANNEL_ID=
# BCP-47 language code (default en-US)
# GOOGLE_TTS_LANGUAGE=en-US
# Specific voice name (e.g. en-US-Neural2-D); blank = Google picks default for the language
# GOOGLE_TTS_VOICE_NAME=
# Speaking rate 0.25-4.0 (default 1.0); pitch -20 to 20 (default 0)
# GOOGLE_TTS_SPEAKING_RATE=1.0
# GOOGLE_TTS_PITCH=0
# Max text chars per TTS utterance (default 4000)
# VOICE_TTS_MAX_CHARS=4000
# Auto-leave empty VC after N seconds (default 300 = 5 min; 0 = never)
VOICE_AUTO_LEAVE_SECONDS=300
# Guild text channel ID(s): AI replies without @mention (pair with AI Support VC). Required for voice STT replies unless VOICE_STT_REPLY_TEXT_CHANNEL_ID is set.
# VOICE_AI_TEXT_CHANNEL_IDS=
# Transcribe speech in VC (Google Cloud Speech-to-Text; enable API + Speech-to-Text User on service account)
# VOICE_STT_ENABLED=0
# Optional: post voice transcripts / AI replies here; defaults to first ID in VOICE_AI_TEXT_CHANNEL_IDS
# VOICE_STT_REPLY_TEXT_CHANNEL_ID=
# VOICE_STT_COOLDOWN_MS=5000

# Staff react on bot AI replies (positive / negative). Logs to AI_FEEDBACK_LOG_CHANNEL_ID or STAFF_LOG
# AI_FEEDBACK_REACTIONS_ENABLED=1
# AI_FEEDBACK_POSITIVE_EMOJI=
# AI_FEEDBACK_NEGATIVE_EMOJI=
# AI_FEEDBACK_LOG_CHANNEL_ID=
