{
  "name": "nd-discord-gemini-bot",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "bun run src/bot.ts",
    "dev": "bun --watch run src/bot.ts",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "test": "bun test",
    "ci": "bun test && (bun run typecheck || true) && (bun run lint || true)",
    "pm2:start": "bunx pm2 start ecosystem.config.cjs",
    "pm2:stop": "bunx pm2 stop nd-bot",
    "pm2:restart": "bunx pm2 restart nd-bot --update-env",
    "pm2:logs": "bunx pm2 logs nd-bot",
    "pm2:status": "bunx pm2 status"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.95.1",
    "@google/generative-ai": "^0.24.0",
    "@napi-rs/canvas": "^1.0.0",
    "@noble/ciphers": "^2.2.0",
    "@sentry/node": "^10.54.0",
    "discord.js": "14.26.1",
    "dotenv": "^16.4.7",
    "jszip": "^3.10.1",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3"
  },
  "trustedDependencies": [
    "protobufjs"
  ],
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@types/bun": "^1.3.14",
    "@types/node": "^25.9.1",
    "typescript": "^6.0.3"
  }
}
